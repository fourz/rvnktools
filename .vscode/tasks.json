{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "mcpServer",
            "description": "Select target server",
            "type": "pickString",
            "options": [
                "rvnk-dev",
                "rvnk-test",
                "rvnk-prod"
            ],
            "default": "rvnk-dev"
        },
        {
            "id": "mcpConsoleLine",
            "description": "Number of console lines to retrieve",
            "type": "pickString",
            "options": ["25", "50", "100", "200", "500"],
            "default": "50"
        },
        {
            "id": "mcpCommand",
            "description": "Command to send to the server (without /)",
            "type": "promptString",
            "default": "rvnktools debug"
        },
        {
            "id": "mcpRemotePath",
            "description": "Remote path on server",
            "type": "promptString",
            "default": "/plugins"
        },
        {
            "id": "serverCommand",
            "description": "Enter the command to send to the server",
            "default": "rvnktools debug",
            "type": "promptString"
        },
        {
            "id": "versionType",
            "description": "Select version increment type",
            "default": "patch",
            "type": "pickString",
            "options": [
                "patch",
                "minor", 
                "major"
            ]
        },
        {
            "id": "customVersion",
            "description": "Enter custom version (e.g., 1.2.0-alpha) or leave empty for automatic increment",
            "default": "",
            "type": "promptString"
        },
        {
            "id": "rvnkApiQueryType",
            "description": "Select RVNKCore API query type",
            "default": "test",
            "type": "pickString",
            "options": [
                "test",
                "players",
                "announcements",
                "player",
                "announcement",
                "custom"
            ]
        },
        {
            "id": "rvnkApiEndpoint",
            "description": "Enter API endpoint (e.g., /api/v1/players)",
            "default": "/api/v1/players",
            "type": "promptString"
        },
        {
            "id": "rvnkApiMethod",
            "description": "Select HTTP method",
            "default": "GET",
            "type": "pickString",
            "options": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
            ]
        }
    ],
    "tasks": [
        {
            "label": "Build Plugin",
            "type": "shell",
            "command": "mvn clean package",
            "options": {
                "cwd": "${workspaceFolder}\\toolkitplugin"
            },
            "group": {
                "kind": "build",
                "isDefault": true                
            },
            "detail": "Compiles and packages the Spigot plugin using Maven.",
            "presentation": {
                "reveal": "always",
                "clear": true,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Copy to Dev Server",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File C:\\tools\\rvnktools\\.vscode\\copyto-server-DEV.ps1",
            "options": {
                "cwd": "${workspaceFolder}\\toolkitplugin"
            },
            "group": "build",
            //"dependsOn": "Build Plugin",
            "detail": "Copies the built plugin JAR to the development server plugins folder. 'Build Plugin' task may need to be run first.",
            "presentation": {
                "reveal": "always",
                "echo": false,                
                "clear": false,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Restart Dev Server",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File C:\\tools\\rvnktools\\.vscode\\restart-server-DEV.ps1",
            "options": {
                "cwd": "${workspaceFolder}\\toolkitplugin"
            },
            "group": {
                "kind": "build"
            },
            //"dependsOn": "Copy to Dev Server",
            "detail": "Performs a full development server restart. Best used after 'Copy to Dev Server' task to apply changes. May take up to 30 seconds to complete.",
            "presentation": {
                "reveal": "always",
                "echo": false,                
                "clear": false,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Reload Server",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File C:\\tools\\rvnktools\\.vscode\\reload-server-DEV.ps1",
            "options": {
                "cwd": "${workspaceFolder}\\toolkitplugin"
            },
            "group": {
                "kind": "build"
            },
            //"dependsOn": "Copy to Dev Server",
            "detail": "Reloads all plugins without full server restart. Requires 'Copy to Dev Server' task first. Note: Some changes may require a full restart.",
            "presentation": {
                "reveal": "always",
                "echo": false,
                "clear": false,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Cleanup Plugin Folder",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File C:\\tools\\rvnktools\\.vscode\\cleanup-folder-DEV.ps1",
            "options": {
                "cwd": "${workspaceFolder}\\toolkitplugin"
            },
            "group": {
                "kind": "build"
            },
            "detail": "Cleans up server files, SQLite databases, and plugin data. Should be run before applying major changes.",
            "presentation": {
                "reveal": "always",
                "echo": false,
                "clear": false,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Clean Jar",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "C:\\tools\\rvnktools\\.vscode\\cleanup-jar-DEV.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "detail": "Remove old RVNKTools JAR files from development server plugins folder. Use before version increment to clean up old versions.",
            "presentation": {
                "reveal": "always",
                "echo": true,
                "clear": true,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Clean&Restart Server",
            "type": "shell",
            "dependsOn": ["Cleanup Plugin Folder", "Restart Dev Server"],
            "group": {
                "kind": "build"
            },
            "detail": "Comprehensive cleanup followed by development server restart. Runs 'Cleanup Plugin Folder' then 'Restart Dev Server' in sequence. Best for major updates.",
            "presentation": {
                "reveal": "always",
                "echo": false,
                "clear": false,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Clean&Reload Server",
            "type": "shell",
            "dependsOn": ["Cleanup Plugin Folder", "Reload Server"],
            "group": {
                "kind": "build"
            },
            "detail": "Comprehensive cleanup followed by plugin reload. Runs 'Cleanup Plugin Folder' then 'Reload Server' in sequence. For changes that don't require full restart.",
            "presentation": {
                "reveal": "always",
                "echo": false,
                "clear": false,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Query Console - Recent",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass", 
                "-File", "C:\\tools\\rvnktools\\.vscode\\query-server-DEV.ps1",
                "console", "50"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "detail": "Get the last 50 console log entries from the development server. Supports 1-500 lines or 'all'.",
            "presentation": {
                "reveal": "always",
                "echo": true,
                "clear": true,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Query Console - Errors Only",
