            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "detail": "Get detailed server configuration and setup information.",
            "presentation": {
                "reveal": "always",
                "echo": true,
                "clear": true,
                "panel": "shared",
                "showReuseMessage": false
