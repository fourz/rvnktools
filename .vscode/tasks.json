            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "Send Server Command",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass", 
                "-File", "C:\\tools\\rvnktools\\.vscode\\query-server-DEV.ps1",
                "command", "${input:serverCommand}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "detail": "Send a command to the development server and show the output.",
            "presentation": {
                "reveal": "always",
                "echo": true,
                "clear": true,
                "panel": "shared",
                "showReuseMessage": false
