            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "detail": "Get console messages containing 'RVNKTools' from last 100 entries. Supports 1-500 lines or 'all'.",
            "presentation": {
                "reveal": "always",
