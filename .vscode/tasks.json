            "args": [
                "-ExecutionPolicy", "Bypass", 
                "-File", "C:\\tools\\rvnktools\\.vscode\\query-server-DEV.ps1",
                "console", "50", "-ErrorsOnly"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "detail": "Get recent error and warning messages from console. Supports 1-500 lines or 'all'.",
            "presentation": {
                "reveal": "always",
                "echo": true,
                "clear": true,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
