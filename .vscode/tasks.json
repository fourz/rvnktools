            },
            "detail": "Complete build and deployment sequence: Builds the plugin, copies to dev server, and performs full restart.",
            "presentation": {
                "reveal": "always",
                "echo": true,
                "clear": true,
                "panel": "shared",
                "showReuseMessage": false
            },
            "runOptions": {
                "runOn": "default"
            }
        },
        {
            "label": "RVNKTools Debug",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass", 
                "-File", "C:\\tools\\rvnktools\\.vscode\\query-server-DEV.ps1",
